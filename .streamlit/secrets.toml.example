# ============================================================
# ClimateNexus — Streamlit Cloud Secrets Template
# ============================================================
# Copy this file to .streamlit/secrets.toml for local dev,
# or paste these values into the Streamlit Cloud dashboard
# under App Settings → Secrets.
#
# NEVER commit the real secrets.toml to version control.
# ============================================================

# Google Gemini API key (used for LLM + embeddings)
GOOGLE_API_KEY = "your-google-api-key-here"

# URL of the deployed FastAPI backend (e.g., on Render)
# For local development, use: http://127.0.0.1:8000
API_BASE_URL = "https://your-backend-app.onrender.com"
