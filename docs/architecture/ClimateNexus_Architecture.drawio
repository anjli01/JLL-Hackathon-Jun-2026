        </mxCell>
        <mxCell id="ep-batch" value="&lt;b&gt;POST /score/batch&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Request: BatchRiskScoreRequest&lt;br&gt;  • addresses: List[str] (max 200)&lt;br&gt;Response: BatchRiskScoreResponse&lt;br&gt;  • results: List[RiskScoreResponse]&lt;br&gt;  • portfolio_summary: PortfolioSummary&lt;br&gt;  • errors: List[BatchErrorItem]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#009688;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="api-group">
          <mxGeometry x="245" y="50" width="240" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="ep-csv" value="&lt;b&gt;POST /score/upload-csv&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Request: UploadFile (CSV)&lt;br&gt;  • 'address' column required&lt;br&gt;Response: BatchRiskScoreResponse&lt;br&gt;  • Same as /score/batch&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#009688;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="api-group">
          <mxGeometry x="495" y="50" width="200" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="ep-strategize" value="&lt;b&gt;POST /agent/strategize&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Request: StrategyRequest&lt;br&gt;  • addresses: List[str] (max 50)&lt;br&gt;  • user_context: str&lt;br&gt;Response: StrategyResponse&lt;br&gt;  • recommendations, narrative,&lt;br&gt;  • total_incentives/savings_usd,&lt;br&gt;  • risk_details, regulations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="api-group">
