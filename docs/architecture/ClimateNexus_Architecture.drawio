        <mxCell id="model-list" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Request Models:&lt;/b&gt;&lt;br&gt;• RiskScoreRequest {address}&lt;br&gt;• BatchRiskScoreRequest {addresses[]}&lt;br&gt;• StrategyRequest {addresses[], user_context}&lt;br&gt;• ChatRequest {message, history[], context}&lt;br&gt;• ReportRequest {strategy, report_title}&lt;br&gt;&lt;br&gt;&lt;b&gt;Response Models:&lt;/b&gt;&lt;br&gt;• RiskScoreResponse {address, lat, lon,&lt;br&gt;  composite_score, EAL, sub_scores,&lt;br&gt;  shap_explanations, raw_features}&lt;br&gt;• SubScores {flood, heat, wildfire,&lt;br&gt;  transition, seismic, elevation}&lt;br&gt;• BatchRiskScoreResponse {results[],&lt;br&gt;  portfolio_summary, errors[]}&lt;br&gt;• PortfolioSummary {total_properties,&lt;br&gt;  avg/max/min_score, risk_counts,&lt;br&gt;  total_EAL, top_hazards}&lt;br&gt;• StrategyResponse {recommendations[],&lt;br&gt;  narrative, portfolio_summary,&lt;br&gt;  total_incentives/savings, risk_details,&lt;br&gt;  regulations[]}&lt;br&gt;• RecommendationItem {category, action,&lt;br&gt;  priority, affected_properties[],&lt;br&gt;  cost, savings, payback, incentives[]}&lt;br&gt;• ChatResponse {reply, updated_recs}&lt;br&gt;• BatchErrorItem {address, error}&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="models-group">
