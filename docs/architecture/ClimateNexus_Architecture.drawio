        <!-- Stage 1 Endpoints -->
        <mxCell id="ep-score" value="&lt;b&gt;POST /score&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Request: RiskScoreRequest&lt;br&gt;  • address: str&lt;br&gt;Response: RiskScoreResponse&lt;br&gt;  • composite_score, sub_scores,&lt;br&gt;  • shap_explanations, raw_features,&lt;br&gt;  • expected_annual_loss_usd&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#009688;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="api-group">
